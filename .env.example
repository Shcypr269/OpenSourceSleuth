# SourceSleuth Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# PATHS
# =============================================================================

# Directory containing your academic PDFs for indexing
# Default: <project_root>/student_pdfs
SOURCESLEUTH_PDF_DIR=/path/to/your/pdfs

# Directory for persisting the vector store and metadata
# Default: <project_root>/data
SOURCESLEUTH_DATA_DIR=/path/to/your/data

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Sentence transformer model for embeddings
# Options: all-MiniLM-L6-v2 (default), all-mpnet-base-v2, etc.
SOURCESLEUTH_EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# CHUNKING CONFIGURATION
# =============================================================================

# Target chunk size in tokens (approximate)
# Default: 500 tokens (~2000 characters)
SOURCESLEUTH_CHUNK_SIZE=500

# Overlap between consecutive chunks in tokens
# Default: 50 tokens
SOURCESLEUTH_CHUNK_OVERLAP=50

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================

# Default number of results to return
# Default: 5
SOURCESLEUTH_TOP_K=5

# Minimum similarity score threshold (0.0 to 1.0)
# Results below this threshold will be filtered out
# Default: 0.3
SOURCESLEUTH_MIN_SCORE=0.3

# =============================================================================
# ARXIV CONFIGURATION
# =============================================================================

# Maximum number of arXiv records to fetch in a single ingestion
# Default: 5000
SOURCESLEUTH_ARXIV_MAX_RECORDS=5000

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
SOURCESLEUTH_LOG_LEVEL=INFO

# Log file path (optional, leave empty for console-only logging)
# SOURCESLEUTH_LOG_FILE=/path/to/sourcesleuth.log

# =============================================================================
# WEB UI CONFIGURATION (Streamlit)
# =============================================================================

# Server port for the Streamlit web UI
# Default: 8501
# SOURCESLEUTH_WEB_PORT=8501

# Server address for the Streamlit web UI
# Default: localhost
# SOURCESLEUTH_WEB_ADDRESS=localhost
